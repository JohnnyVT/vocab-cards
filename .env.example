# Copy this file to ".env" (which is git-ignored) and put your real key in it.
#   cp .env.example .env
# Then generate audio with:
#   node --env-file=.env scripts/gen-audio.mjs content/animals/cards.json
#
# These keys are only used at build time to generate assets.
# They are NEVER bundled into the app and never used at runtime.

# ElevenLabs: voice (gen-audio.mjs) + animal sound effects (gen-sounds.mjs).
# For sound effects the key must have the "Sound Generation" permission enabled.
ELEVENLABS_API_KEY=sk_your_key_here

# xAI (Grok): for generating animations via the xAI API (scripts/gen-videos via API).
XAI_API_KEY=xai-your_key_here
